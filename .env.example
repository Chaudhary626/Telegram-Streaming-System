# ═══════════════════════════════════════════════════════════
# TG Stream Server — Environment Configuration
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control!

# ─── Telegram Credentials ────────────────────────────────
# Get API_ID and API_HASH from: https://my.telegram.org
# These are REQUIRED for MTProto (bypasses 20MB Bot API limit)
API_ID=12345678
API_HASH=your_api_hash_from_my_telegram_org

# Bot token from @BotFather
BOT_TOKEN=7123456789:AAHxyz_your_bot_token_here

# Your Telegram channel ID (starts with -100)
# Get it: forward a channel message to @RawDataBot → look for chat.id
CHANNEL_ID=-1001234567890

# ─── Database (same as your PHP website) ─────────────────
# IMPORTANT: Enable "Remote MySQL" in Hostinger hPanel if using external server
DB_HOST=your-mysql-host.com
DB_PORT=3306
DB_NAME=u602666777_galaxy
DB_USER=u602666777_galaxy
DB_PASS=your_db_password

# ─── Stream Server ──────────────────────────────────────
# Shared secret — MUST match STREAM_SERVER_SECRET in PHP config.php
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
STREAM_SECRET=change_me_to_a_random_64_char_hex_string

# Public URL of this server (REQUIRED for bot link generation)
# Examples:
#   Railway:  https://your-app.railway.app
#   Render:   https://your-app.onrender.com
#   VPS:      https://stream.yourdomain.com
STREAM_BASE_URL=https://your-app.onrender.com

# Server binding
STREAM_HOST=0.0.0.0
STREAM_PORT=8080

# ─── Security ───────────────────────────────────────────
# Token lifetime in seconds (default: 4 hours)
TOKEN_LIFETIME=14400

# Allowed origins for CORS (comma-separated, or * for all)
ALLOWED_ORIGINS=https://animegalaxyhub.com,https://www.animegalaxyhub.com

# ─── Performance ────────────────────────────────────────
# MTProto chunk size (bytes). 1MB = 1048576. Max: 1MB
CHUNK_SIZE=1048576

# Max concurrent streams per IP (0 = unlimited)
MAX_STREAMS_PER_IP=5
